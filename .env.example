# ── AI Insight Agent — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ── Model ─────────────────────────────────────────────────────────────────────
# MODEL_DIR=ml/models          # default; override if artifacts are stored elsewhere
# CONTAMINATION=0.05           # expected anomaly fraction [0.001, 0.5]

# ── Severity thresholds ───────────────────────────────────────────────────────
# SEVERITY_CRITICAL_THRESHOLD=0.80
# SEVERITY_HIGH_THRESHOLD=0.60
# SEVERITY_MEDIUM_THRESHOLD=0.40

# ── PostgreSQL (read-only) ────────────────────────────────────────────────────
# POSTGRES_HOST=
# POSTGRES_PORT=5432
# POSTGRES_DB=
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_CONNECT_TIMEOUT=10
# POSTGRES_QUERY_TIMEOUT_MS=30000

# ── MongoDB (read-only) ───────────────────────────────────────────────────────
# MONGODB_URL=
# MONGODB_DB=file_tracking

# ── CSV source ────────────────────────────────────────────────────────────────
# CSV_PATH=                     # absolute path; auto-detected if blank

# ── API ───────────────────────────────────────────────────────────────────────
# API_HOST=0.0.0.0
# API_PORT=8001
# API_RATE_LIMIT=100

# ── AWS (CloudWatch metrics — optional) ──────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# CLOUDWATCH_LOG_GROUP=

# ── Legacy database (existing app modules) ───────────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/dbname
